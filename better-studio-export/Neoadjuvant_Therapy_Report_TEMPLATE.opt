ons><term_definitions code="at0003"><items id="text">Ever used?</items><items id="description">Has the individual ever used the medication or class of medication?</items></term_definitions><term_definitions code="at0004"><items id="text">Current use?</items><items id="description">Is the individual currently using the medication or class of medications?</items></term_definitions><term_definitions code="at0005"><items id="text">Tree</items><items id="description">@ internal @</items></term_definitions><term_definitions code="at0006"><items id="text">Last updated</items><items id="description">The date this medication summary was last updated.</items></term_definitions><term_definitions code="at0007"><items id="text">Clinical description</items><items id="description">Narrative description about the medication use.</items></term_definitions><term_definitions code="at0008"><items id="text">Episode</items><items id="description">Details about each episode of use.</items></term_definitions><term_definitions code="at0009"><items id="text">Onset of use</items><items id="description">First ever onset of use.</items></term_definitions><term_definitions code="at0010"><items id="text">Cessation of use</items><items id="description">Most recent cessation of use.</items></term_definitions><term_definitions code="at0011"><items id="text">Episode onset</items><items id="description">The date of onset for this episode of use.</items></term_definitions><term_definitions code="at0012"><items id="text">Episode cessation</items><items id="description">The date of cessation for this episode of use.</items></term_definitions><term_definitions code="at0013"><items id="text">Reason for cessation</items><items id="description">The reason why the medication was ceased.</items></term_definitions><term_definitions code="at0014"><items id="text">Description</items><items id="description">Description of use during the identified episode of use.</items></term_definitions><term_definitions code="at0015"><items id="text">Cumulative dose</items><items id="description">Total amount ever consumed.</items></term_definitions><term_definitions code="at0016"><items id="text">Episode dose</items><items id="description">Total dose for the identified episode.</items></term_definitions><term_definitions code="at0018"><items id="text">Clinical indication</items><items id="description">The clinical indication for the administration or consumption of the medication.</items></term_definitions><term_definitions code="at0019"><items id="text">Extension</items><items id="description">Additional information required to capture local content or to align with other reference models/formalisms.</items><items id="comment">For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items></term_definitions><term_definitions code="at0020"><items id="text">Intent</items><items id="description">Intent for use.</items><items id="comment">For example: palliative; short term; or a specified duration</items></term_definitions><term_definitions code="at0021"><items id="text">Specific name</items><items id="description">Specific name of medication.</items><items id="comment">Use to identify the specific medication used if a class is identified in 'Medication name'. Redundant if the name is identified using the 'Medication name' data element.</items></term_definitions></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></interval></cardinality></attributes><archetype_id><value>openEHR-EHR-COMPOSITION.report-result.v1</value></archetype_id><template_id><value>Neoadjuvant Therapy Report</value></template_id><term_definitions code="at0000.1"><items id="text">Neoadjuvant Therapy Report</items><items id="description">Document to communicate inf