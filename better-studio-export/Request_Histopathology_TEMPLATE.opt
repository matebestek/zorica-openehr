te_name>value</rm_attribute_name><existence><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></existence><match_negated>false</match_negated><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>DV_TEXT</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>1</lower><upper>1</upper></occurrences></children></attributes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>2</lower></interval></cardinality></attributes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes><archetype_id><value>openEHR-EHR-CLUSTER.person_name.v0</value></archetype_id><term_definitions code="at0000"><items id="text">Person name</items><items id="description">Details of personal name of an individual, provider or third party.</items></term_definitions><term_definitions code="at0001"><items id="text">Unstructured name</items><items id="description">Name in free text unstructured format.</items></term_definitions><term_definitions code="at0002"><items id="text">Structured name</items><items id="description">Name in structured format.</items></term_definitions><term_definitions code="at0003"><items id="text">Given name</items><items id="description">Given / personal / first name.</items></term_definitions><term_definitions code="at0004"><items id="text">Middle name</items><items id="description">Middle name or names.</items></term_definitions><term_definitions code="at0005"><items id="text">Family name</items><items id="description">Family name or Surname.</items></term_definitions><term_definitions code="at0006"><items id="text">Name type</items><items id="description">Type of name described.</items></term_definitions><term_definitions code="at0008"><items id="text">Previous name</items><items id="description">Name previously used by this person.</items></term_definitions><term_definitions code="at0009"><items id="text">Birth name</items><items id="description">Name given to this person at birth.</items></term_definitions><term_definitions code="at0010"><items id="text">AKA</items><items id="description">Person also known as.</items></term_definitions><term_definitions code="at0011"><items id="text">Alias</items><items id="description">Other name used by this person.</items></term_definitions><term_definitions code="at0012"><items id="text">Maiden name</items><items id="description">Name used by this persion before marriage.</items></term_definitions><term_definitions code="at0014"><items id="text">Validity period</items><items id="description">The date interval at which this name was valid.</items></term_definitions><term_definitions code="at0017"><items id="text">Title</items><items id="description">The prefix or title used by the subject.</items><items id="comment">e.g. 'Mr', 'Mrs', 'Ms', 'Dr', 'Lord'</items></term_definitions><term_definitions code="at0018"><items id="text">Suffix</items><items id="description">Additional term used following a person name.</items><items id="comment">e.g. 'Snr'</items></term_definitions><term_definitions code="at0019"><items id="text">Professional name</items><items id="description">The name used by the subject for business or professional purposes.</items></term_definitions><term_definitions code="at0020"><items id="text">Registered name</items><items id="description">The name by which the subject is officially registered.</items></term_definitions><term_definitions code="at0021"><items id="text">Reporting name</items><items id="description">The subject’s name as it is to be used for reporting, when used with a specific identifier.</items></term_definitions><term_definitions code="at0022"><items id="text">Preferred name</items><items id="description">Indicates that this is the name by which a person chooses to be identified.</items></term_definitions></children><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></occurrences><node_id>at0003</node_id><attributes xsi:type="C_MULTIPLE_ATTRIBUTE"><rm_attribute_name>items</rm_attribute_name><existence><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>1</lower><upper>1</upper></existence><match_negated>false</match_negated><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0016</node_id><includes><string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.professional_role\.v1|openEHR-EHR-CLUSTER\.professional_role\.v0/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>openEHR-EHR-CLUSTER\.professional_role\.v1|openEHR-EHR-CLUSTER\.professional_role\.v0</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>ELEMENT</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></occurrences><node_id>at0011</node_id><attributes xsi:type="C_SINGLE_ATTRIBUTE"><rm_attribute_name>value</rm_attribute_name><existence><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></existence><match_negated>false</match_negated><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>DV_TEXT</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>1</lower><upper>1</upper></occurrences></children></attributes></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0017</node_id><includes><string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.telecom_details(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.telecom_details\.v0/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>openEHR-EHR-CLUSTER\.telecom_details(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.telecom_details\.v0</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0019</node_id><includes><string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.address(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.address\.v0/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>openEHR-EHR-CLUSTER\.address(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.address\.v0</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0018</node_id><includes><string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.organisation\.v0|openEHR-EHR-CLUSTER\.organisation\.v1/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>openEHR-EHR-CLUSTER\.organisation\.v0|openEHR-EHR-CLUSTER\.organisation\.v1</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes><archetype_id><value>openEHR-EHR-CLUSTER.individual_professional.v0</value></archetype_id><term_definitions code="at0000"><items id="text">Professional Individual demographics</items><items id="description">Professional demographics details including name(s) , addresse(s) and telecommunication contact details.</items></term_definitions><term_definitions code="at0003"><items id="text">Professional details</items><items id="description">Details of a professional carer.</items></term_definitions><term_definitions code="at0005"><items id="text">Grade</items><items id="description">The employment grade or position of the carer.</items></term_definitions><term_definitions code="at0006"><items id="text">Specialty</items><items id="description">The speciality of the carer.</items></term_definitions><term_definitions code="at0011"><items id="text">Professional Identifier</items><items id="description">Professional identifier of the individual.</items></term_definitions><term_definitions code="at0012"><items id="text">Team</items><items id="description">Team to which the individual belongs.</items></term_definitions><term_definitions code="at0013"><items id="text">Period of involvement</items><items id="description">The period during which this professional was involved in care of the subject.</items></term_definitions><term_definitions code="at0015"><items id="text">Name</items><items id="description">Personal name details of the individual.</items></term_definitions><term_definitions code="at0016"><items id="text">Professional Role</items><items id="description">Professional role details of the individual.</items></term_definitions><term_definitions code="at0017"><items id="text">Telecoms</items><items id="description">Telecommunication details of the individual.</items></term_definitions><term_definitions code="at0018"><items id="text">Organisation</items><items id="description">Organisation details to which the individual is attached.</items></term_definitions><term_definitions code="at0019"><items id="text">Address</items><items id="description">Address details of the individual.</items></term_definitions></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes><archetype_id><value>openEHR-EHR-CLUSTER.organisation.v0</value></archetype_id><term_definitions code="at0000"><items id="text">Organisation</items><items id="description">Details of an organisation.</items></term_definitions><term_definitions code="at0001"><items id="text">Organisation name</items><items id="description">Name of the organisation.</items></term_definitions><term_definitions code="at0005"><items id="text">Contact details</items><items id="description">Details about a contact person within organisation.</items></term_definitions><term_definitions code="at0007"><items id="text">Role in organisation</items><items id="description">Contact person's role in organisation.</items></term_definitions><term_definitions code="at0008"><items id="text">Address details</items><items id="description">Details about address.</items></term_definitions><term_definitions code="at0009"><items id="text">Telecom details</items><items id="description">Details about telecommunications.</items></term_definitions><term_definitions code="at0010"><items id="text">Contact name</items><items id="description">Name of the contact person.</items></term_definitions><term_definitions code="at0011"><items id="text">Identifier</items><items id="description">Identifier of organisation.</items></term_definitions></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></occurrences><node_id>at0142</node_id><includes><string_expression>archetype_id/value matches {/.*/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>.*</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>ELEMENT</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></occurrences><node_id>at0127</node_id><attributes xsi:type="C_SINGLE_ATTRIBUTE"><rm_attribute_name>value</rm_attribute_name><existence><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></existence><match_negated>false</match_negated><children xsi:type="C_COMPLEX_OBJECT"><rm_type_name>DV_CODED_TEXT</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>1</lower><upper>1</upper></occurrences><attributes xsi:type="C_SINGLE_ATTRIBUTE"><rm_attribute_name>defining_code</rm_attribute_name><existence><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>1</lower><upper>1</upper></existence><match_negated>false</match_negated><children xsi:type="C_CODE_REFERENCE"><rm_type_name>CODE_PHRASE</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>true</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>false</upper_unbounded><lower>0</lower><upper>1</upper></occurrences><referenceSetUri>terminology:B02_request_status</referenceSetUri></children></attributes></children></attributes></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0128</node_id><includes><string_expression>archetype_id/value matches {/openEHR-EHR-CLUSTER\.distribution\.v1/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>openEHR-EHR-CLUSTER\.distribution\.v1</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><children xsi:type="ARCHETYPE_SLOT"><rm_type_name>CLUSTER</rm_type_name><occurrences><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></occurrences><node_id>at0112</node_id><includes><string_expression>archetype_id/value matches {/.*/}</string_expression><expression xsi:type="EXPR_BINARY_OPERATOR"><type>Boolean</type><operator>2007</operator><precedence_overridden>false</precedence_overridden><left_operand xsi:type="EXPR_LEAF"><type>String</type><item xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">archetype_id/value</item><reference_type>attribute</reference_type></left_operand><right_operand xsi:type="EXPR_LEAF"><type>String</type><item xsi:type="C_STRING"><pattern>.*</pattern></item><reference_type>constraint</reference_type></right_operand></expression></includes></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>1</lower></interval></cardinality></attributes></children></attributes><archetype_id><value>openEHR-EHR-INSTRUCTION.service_request.v1</value></archetype_id><term_definitions code="at0000"><items id="text">Service request</items><items id="description">Request for a health-related service or activity to be delivered by a clinician, organisation or agency.</items></term_definitions><term_definitions code="at0001"><items id="text">Current Activity</items><items id="description">Current Activity.</items></term_definitions><term_definitions code="at0008"><items id="text">Tree</items><items id="description">@ internal @</items></term_definitions><term_definitions code="at0009"><items id="text">Tree</items><items id="description">@ internal @</items></term_definitions><term_definitions code="at0010"><items id="text">Requester order identifier</items><items id="description">The local identifier assigned by the requesting clinical system.</items><items id="comment">Usually equivalent to the HL7 Placer Order Identifier.</items></term_definitions><term_definitions code="at0011"><items id="text">Receiver order identifier</items><items id="description">The local identifier assigned to the request by the clinician or organisation receiving the request for service.</items><items id="comment">Usually equivalent to the HL7 Filler Order Identifier.</items></term_definitions><term_definitions code="at0040"><items id="text">Service due</items><items id="description">The date/time, or acceptable interval of date/time, for provision of the service.</items><items id="comment">This data element allows for recording of the timing for a single service, either as a date and time, a date ranges or a text descriptor which can allow for 'next available. In practice, clinicians will often think in terms of ordering services as approximate timing, for example: review in 3 months, 6 months or 12 months. As clinical systems need more exact parameters to operate on, this '3 months' will usually be converted to an exact date 3 months from the date of recording and stored using this data element. If complex timing or sequences of timings are required, use the CLUSTER.service_direction archetype within the 'Complex timing' SLOT and this data element becomes redundant.</items></term_definitions><term_definitions code="at0062"><items id="text">Reason for request</items><items id="description">A short phrase describing the reason for the request.</items><items id="comment">Coding of the 'Reason for request' with a coding system is desirable, if available. This data element allows multiple occurrences to enable the user to record a multiple responses, if required. For example: 'manage diabetes complications'.</items></term_definitions><term_definitions code="at0064"><items id="text">Reason description</items><items id="description">Narrative description about the reason for request.</items><items id="comment">For example: 'The patient's diabetes has recently become more difficult to stabilise and renal function is deteriorating'.</items></term_definitions><term_definitions code="at0065"><items id="text">Intent</items><items id="description">Description of the intent for the request.</items><items id="comment">For example: a referral to a specialist may have the intent of the specialist taking over responsibility for care of the patient, or it may be to provide a second opinion on treatment options. Coding of the 'Intent' with a coding system is desirable, if available. This data element allows multiple occurrences to enable the user to record a multiple responses, if required.</items></term_definitions><term_definitions code="at0068"><items id="text">Urgency</items><items id="description">Urgency of the request for service.</items><items id="comment">Specific definitions of emergency and urgent will vary between clinical contexts, clinical systems and the nature of the request itself, so have not been defined in this archetype. If explicit timing is required then the Service period should be clearly stated.</items></term_definitions><term_definitions code="at0076"><items id="text">Supplementary information</items><items id="description">Supplementary information will be following request.</items><items id="comment">Record as TRUE if additional information has been identified and will be forwarded when available. For example: pending test results.</items></term_definitions><term_definitions code="at0078"><items id="text">Information description</items><items id="description">Description of the supplementary information.</items></term_definitions><term_definitions code="at0112"><items id="text">Extension</items><items id="description">Additional information required to capture local content or to align with other reference models/formalisms.</items><items id="comment">For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items></term_definitions><term_definitions code="at0116"><items id="text">Patient requirements</items><items id="description">Language, transport or other personal requirements to support the patient's attendance or participation in provision of the service.</items></term_definitions><term_definitions code="at0121"><items id="text">Service name</items><items id="description">The name of the single service or activity requested.</items><items id="comment">Coding of the 'Service name' with a coding system is desirable, if available. For example: 'referral' to an endocrinologist for diabetes management.</items></term_definitions><term_definitions code="at0127"><items id="text">Request status</items><items id="description">The status of the request for service as indicated by the requester.</items><items id="comment">Status is used to denote whether this is the initial request, or a follow-up request to change or provide supplementary information. Coding with a terminology is preferred, where possible.</items></term_definitions><term_definitions code="at0128"><items id="text">Distribution list</items><items id="description">Details of additional clinicians, organisations or agencies who require copies of any communication.</items></term_definitions><term_definitions code="at0132"><items id="text">Specific details</items><items id="description">Additional detail about the service requested.</items><items id="comment">For example: Specimen details for a laboratory test request, or anatomical location for a procedure request.</items></term_definitions><term_definitions code="at0135"><items id="text">Procedure type</items><items id="description">Narrative description about the service requested.</items><items id="comment">This data point should be used to describe the named service in more detail, including how it should be delivered, patient concerns and issues that might be encountered in delivering the service.</items></term_definitions><term_definitions code="at0141"><items id="text">Requester</items><items id="description">Details about the clinician or organisation requesting the service.</items></term_definitions><term_definitions code="at0142"><items id="text">Receiver</items><items id="description">Details about the clinician or organisation receiving the request for service.</items></term_definitions><term_definitions code="at0144"><items id="text">Service period expiry</items><items id="description">The date/time that marks the conclusion of the clinically valid period of time for delivery of this service.</items><items id="comment">This date/time is the equivalent to the latest possible date for service delivery or to the date of expiry for this request. For example: a service may be required to be completed before another event, such as scheduled surgery.</items></term_definitions><term_definitions code="at0145"><items id="text">Service period start</items><items id="description">The date/time that marks the beginning of the valid period of time for delivery of this service.</items><items id="comment">This date/time is the equivalent to the earliest possible date for service delivery. For example: sometimes a certain amount of time must pass before a service can be performed, for example some procedures can only be performed once the patient has stopped taking medications for a specific amount of time.</items></term_definitions><term_definitions code="at0147"><items id="text">Indefinite?</items><items id="description">The valid period for this request is open ended and has no date of expiry.</items><items id="comment">Record as TRUE to record explicity that the request has no expiry date. For example: commonly required for a referral to a specialist for long-term or lifelong care.</items></term_definitions><term_definitions code="at0148"><items id="text">Service type</items><items id="description">Category of service requested.</items><items id="comment">Coding of the 'Service type' with a coding system is desirable, if available. If the 'Service name' was coded, it is possible for this data point to be derived from the code. For example: biochemistry or microbiology laboratory, ultrasound or CT imaging.</items></term_definitions><term_definitions code="at0149"><items id="text">Supporting information</items><items id="description">Digital document, image, video or diagram supplied as additional information to support or inform the request.</items></term_definitions><term_definitions code="at0150"><items id="text">Comment</items><items id="description">Additional narrative about the service request not captured in other fields.</items></term_definitions><term_definitions code="at0151"><items id="text">Complex timing</items><items id="description">Details about a complex service request requiring a sequence of timings.</items><items id="comment">For example: 'hourly vital signs observations for 4 hours, then 4 hourly for 20 hours' or 'every third Wednesday for 3 visits' or .</items></term_definitions><term_definitions code="at0152"><items id="text">Clinical indication</items><items id="description">The clinical reason for the ordered service.</items><items id="comment">Coding of the clinical indication with a terminology is preferred, where possible. This data element allows multiple occurrences. For example: 'Angina' or 'Type 1 Diabetes mellitus'.</items></term_definitions></children><cardinality><is_ordered>false</is_ordered><is_unique>false</is_unique><interval><lower_included>true</lower_included><upper_included>false</upper_included><lower_unbounded>false</lower_unbounded><upper_unbounded>true</upper_unbounded><lower>0</lower></interval></cardinality></attributes><archetype_id><value>openEHR-EHR-COMPOSITION.request.v1</value></archetype_id><template_id><value>Request Histopathology</value></template_id><term_definitions code="at0000"><items id="text">Request Histopathology</items><items id="description">Document sent from one treating healthcare provider or organisation to another, for the purpose of requesting advice, a service or transfer of care.</items></term_definitions><term_definitions code="at0001"><items id="text">Tree</items><items id="description">@ internal @</items></term_definitions><term_definitions code="at0042"><items id="text">Extension</items><items id="description">Additional information required to capture local context or to align with other reference models/formalisms.</items><items id="comment">For example: Local hospital departmental information or additional metadata to align with FHIR or CIMI equivalents.</items></term_definitions></definition><ontology archetype_id="openEHR-EHR-COMPOSITION.request.v1"><term_definitions language="sl"><items code="at0000"><items id="text">Zahtevek za histopatološki izvid</items><items id="description">*Document sent from one treating healthcare provider or organisation to another, for the purpose of requesting advice, a service or transfer of care. (en)</items></items><items code="at0001"><items id="text">Tree</items><items id="description">@ internal @</items></items><items code="at0042"><items id="text">*Extension (en)</items><items id="description">*Additional information required to capture local context or to align with other reference models/formalisms. (en)</items><items id="comment">For example: Local hospital departmental information or additional metadata to align with FHIR or CIMI equivalents.</items></items></term_definitions></ontology><component_ontologies archetype_id="openEHR-EHR-CLUSTER.composition_context_detail.v1"><term_definitions language="sl"><items code="at0000"><items id="text">Podrobnosti</items><items id="description">Dodatni podatki o kontekstu</items></items><items code="at0003"><items id="text">ID smernice</items><items id="description">*</items></items><items code="at0004"><items id="text">Verzija</items><items id="description">*</items></items><items code="at0005"><items id="text">Referenca</items><items id="description">*</items></items><items code="at0006"><items id="text">Razširitev</items><items id="description">*</items></items><items code="at0007"><items id="text">Datum in ura</items><items id="description">*</items></items><items code="at0008"><items id="text">ID izvida</items><items id="description">*</items></items><items code="at0010"><items id="text">Memo</items><items id="description">*</items></items><items code="at0011"><items id="text">Komentar</items><items id="description">*</items></items><items code="at0012"><items id="text">Verzija</items><items id="description">*</items></items><items code="at0014"><items id="text">Status</items><items id="description">*</items></items><items code="at0015"><items id="text">ID zahtevka</items><items id="description">*</items></items><items code="at0016"><items id="text">Samoplačnik</items><items id="description">*</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-INSTRUCTION.service_request.v1"><term_definitions language="sl"><items code="at0000"><items id="text">Zahtevek za storitev</items><items id="description">*Request for a health-related service or activity to be delivered by a clinician, organisation or agency. (en)</items></items><items code="at0001"><items id="text">Trenutna aktivnost</items><items id="description">*Current Activity. (en)</items></items><items code="at0008"><items id="text">Tree</items><items id="description">@ internal @</items></items><items code="at0009"><items id="text">Tree</items><items id="description">@ internal @</items></items><items code="at0010"><items id="text">ID zahtevka naročnika</items><items id="description">*The local identifier assigned by the requesting clinical system. (en)</items><items id="comment">Usually equivalent to the HL7 Placer Order Identifier.</items></items><items code="at0011"><items id="text">ID zahtevka prejemnika</items><items id="description">*The local identifier assigned to the request by the clinician or organisation receiving the request for service. (en)</items><items id="comment">Usually equivalent to the HL7 Filler Order Identifier.</items></items><items code="at0040"><items id="text">Rok dobave storitve</items><items id="description">*The date/time, or acceptable interval of date/time, for provision of the service. (en)</items><items id="comment">This data element allows for recording of the timing for a single service, either as a date and time, a date ranges or a text descriptor which can allow for 'next available. In practice, clinicians will often think in terms of ordering services as approximate timing, for example: review in 3 months, 6 months or 12 months. As clinical systems need more exact parameters to operate on, this '3 months' will usually be converted to an exact date 3 months from the date of recording and stored using this data element. If complex timing or sequences of timings are required, use the CLUSTER.service_direction archetype within the 'Complex timing' SLOT and this data element becomes redundant.</items></items><items code="at0062"><items id="text">Razlog za zahtevek</items><items id="description">*A short phrase describing the reason for the request. (en)</items><items id="comment">Coding of the 'Reason for request' with a coding system is desirable, if available. This data element allows multiple occurrences to enable the user to record a multiple responses, if required. For example: 'manage diabetes complications'.</items></items><items code="at0064"><items id="text">Opis razloga</items><items id="description">*Narrative description about the reason for request. (en)</items><items id="comment">For example: 'The patient's diabetes has recently become more difficult to stabilise and renal function is deteriorating'.</items></items><items code="at0065"><items id="text">Namen</items><items id="description">*Description of the intent for the request. (en)</items><items id="comment">For example: a referral to a specialist may have the intent of the specialist taking over responsibility for care of the patient, or it may be to provide a second opinion on treatment options. Coding of the 'Intent' with a coding system is desirable, if available. This data element allows multiple occurrences to enable the user to record a multiple responses, if required.</items></items><items code="at0068"><items id="text">Nujnost</items><items id="description">*Urgency of the request for service. (en)</items><items id="comment">Specific definitions of emergency and urgent will vary between clinical contexts, clinical systems and the nature of the request itself, so have not been defined in this archetype. If explicit timing is required then the Service period should be clearly stated.</items></items><items code="at0076"><items id="text">Dodatne informacije</items><items id="description">*Supplementary information will be following request. (en)</items><items id="comment">Record as TRUE if additional information has been identified and will be forwarded when available. For example: pending test results.</items></items><items code="at0078"><items id="text">Dodaten opis</items><items id="description">*Description of the supplementary information. (en)</items></items><items code="at0112"><items id="text">*Extension (en)</items><items id="description">*Additional information required to capture local content or to align with other reference models/formalisms. (en)</items><items id="comment">For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items></items><items code="at0116"><items id="text">Zahteve pacienta</items><items id="description">*Language, transport or other personal requirements to support the patient's attendance or participation in provision of the service. (en)</items></items><items code="at0121"><items id="text">Naziv storitve</items><items id="description">*The name of the single service or activity requested. (en)</items><items id="comment">Coding of the 'Service name' with a coding system is desirable, if available. For example: 'referral' to an endocrinologist for diabetes management.</items></items><items code="at0127"><items id="text">Status zahtevka</items><items id="description">*The status of the request for service as indicated by the requester. (en)</items><items id="comment">Status is used to denote whether this is the initial request, or a follow-up request to change or provide supplementary information. Coding with a terminology is preferred, where possible.</items></items><items code="at0128"><items id="text">Seznam prejemnikov</items><items id="description">*Details of additional clinicians, organisations or agencies who require copies of any communication. (en)</items></items><items code="at0132"><items id="text">Podrobnosti</items><items id="description">*Additional detail about the service requested. (en)</items><items id="comment">For example: Specimen details for a laboratory test request, or anatomical location for a procedure request.</items></items><items code="at0135"><items id="text">Opis</items><items id="description">*Narrative description about the service requested. (en)</items><items id="comment">This data point should be used to describe the named service in more detail, including how it should be delivered, patient concerns and issues that might be encountered in delivering the service.</items></items><items code="at0141"><items id="text">Naročnik</items><items id="description">*Details about the clinician or organisation requesting the service. (en)</items></items><items code="at0142"><items id="text">Prejemnik</items><items id="description">*Details about the clinician or organisation receiving the request for service. (en)</items></items><items code="at0144"><items id="text">Zapadlost storitve</items><items id="description">*The date/time that marks the conclusion of the clinically valid period of time for delivery of this service. (en)</items><items id="comment">This date/time is the equivalent to the latest possible date for service delivery or to the date of expiry for this request. For example: a service may be required to be completed before another event, such as scheduled surgery.</items></items><items code="at0145"><items id="text">Začetek storitve</items><items id="description">*The date/time that marks the beginning of the valid period of time for delivery of this service. (en)</items><items id="comment">This date/time is the equivalent to the earliest possible date for service delivery. For example: sometimes a certain amount of time must pass before a service can be performed, for example some procedures can only be performed once the patient has stopped taking medications for a specific amount of time.</items></items><items code="at0147"><items id="text">Brez roka</items><items id="description">*The valid period for this request is open ended and has no date of expiry. (en)</items><items id="comment">Record as TRUE to record explicity that the request has no expiry date. For example: commonly required for a referral to a specialist for long-term or lifelong care.</items></items><items code="at0148"><items id="text">Vrsta storitve</items><items id="description">*Category of service requested. (en)</items><items id="comment">Coding of the 'Service type' with a coding system is desirable, if available. If the 'Service name' was coded, it is possible for this data point to be derived from the code. For example: biochemistry or microbiology laboratory, ultrasound or CT imaging.</items></items><items code="at0149"><items id="text">Podporne informacije</items><items id="description">*Digital document, image, video or diagram supplied as additional information to support or inform the request. (en)</items></items><items code="at0150"><items id="text">Komentar</items><items id="description">*Additional narrative about the service request not captured in other fields. (en)</items></items><items code="at0151"><items id="text">Časovno izvajanje aktivnosti</items><items id="description">*Details about a complex service request requiring a sequence of timings. (en)</items><items id="comment">For example: 'hourly vital signs observations for 4 hours, then 4 hourly for 20 hours' or 'every third Wednesday for 3 visits' or .</items></items><items code="at0152"><items id="text">Klinična indikacija</items><items id="description">*The clinical reason for the ordered service. (en)</items><items id="comment">Coding of the clinical indication with a terminology is preferred, where possible. This data element allows multiple occurrences. For example: 'Angina' or 'Type 1 Diabetes mellitus'.</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.organisation.v0"><term_definitions language="sl"><items code="at0000"><items id="text">Organizacija</items><items id="description">*Details of an organisation. (en)</items></items><items code="at0001"><items id="text">Naziv organizacije</items><items id="description">*Name of the organisation. (en)</items></items><items code="at0005"><items id="text">Kontakt</items><items id="description">*Details about a contact person within organisation. (en)</items></items><items code="at0007"><items id="text">Vloga</items><items id="description">*Contact person's role in organisation. (en)</items></items><items code="at0008"><items id="text">Naslov</items><items id="description">*Details about address. (en)</items></items><items code="at0009"><items id="text">Telefon</items><items id="description">*Details about telecommunications. (en)</items></items><items code="at0010"><items id="text">Ime kontaktne osebe</items><items id="description">*Name of the contact person. (en)</items></items><items code="at0011"><items id="text">ID organizacije</items><items id="description">*Identifier of organisation. (en)</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.individual_professional.v0"><term_definitions language="sl"><items code="at0000"><items id="text">Demografija strokovne osebe</items><items id="description">*Professional demographics details including name(s) , addresse(s) and telecommunication contact details. (en)</items></items><items code="at0003"><items id="text">Strokovne podrobnosti</items><items id="description">*Details of a professional carer. (en)</items></items><items code="at0005"><items id="text">Delovno mesto</items><items id="description">*The employment grade or position of the carer. (en)</items></items><items code="at0006"><items id="text">Specializacija</items><items id="description">*The speciality of the carer. (en)</items></items><items code="at0011"><items id="text">ID naročnika</items><items id="description">*Professional identifier of the individual. (en)</items></items><items code="at0012"><items id="text">Ekipa</items><items id="description">*Team to which the individual belongs. (en)</items></items><items code="at0013"><items id="text">Obdobje obravnave pacienta</items><items id="description">*The period during which this professional was involved in care of the subject. (en)</items></items><items code="at0015"><items id="text">Naziv</items><items id="description">*Personal name details of the individual. (en)</items></items><items code="at0016"><items id="text">Strokovna vloga</items><items id="description">*Professional role details of the individual. (en)</items></items><items code="at0017"><items id="text">Telefon</items><items id="description">*Telecommunication details of the individual. (en)</items></items><items code="at0018"><items id="text">Organizacija</items><items id="description">*Organisation details to which the individual is attached. (en)</items></items><items code="at0019"><items id="text">Naslov</items><items id="description">*Address details of the individual. (en)</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.person_name.v0"><term_definitions language="sl"><items code="at0000"><items id="text">Ime osebe</items><items id="description">*Details of personal name of an individual, provider or third party. (en)</items></items><items code="at0001"><items id="text">Nestrukturirano ime</items><items id="description">*Name in free text unstructured format. (en)</items></items><items code="at0002"><items id="text">Strukturirano ime</items><items id="description">*Name in structured format. (en)</items></items><items code="at0003"><items id="text">Ime</items><items id="description">*Given / personal / first name. (en)</items></items><items code="at0004"><items id="text">Srednje ime</items><items id="description">*Middle name or names. (en)</items></items><items code="at0005"><items id="text">Priimek</items><items id="description">*Family name or Surname. (en)</items></items><items code="at0006"><items id="text">Vrsta imena</items><items id="description">*Type of name described. (en)</items></items><items code="at0008"><items id="text">Bivše ime</items><items id="description">*Name previously used by this person. (en)</items></items><items code="at0009"><items id="text">Rojstno ime</items><items id="description">*Name given to this person at birth. (en)</items></items><items code="at0010"><items id="text">Znan tudi kot</items><items id="description">*Person also known as. (en)</items></items><items code="at0011"><items id="text">Alias</items><items id="description">*Other name used by this person. (en)</items></items><items code="at0012"><items id="text">Dekliški priimek</items><items id="description">*Name used by this persion before marriage. (en)</items></items><items code="at0014"><items id="text">Obdobje veljavnosti</items><items id="description">*The date interval at which this name was valid. (en)</items></items><items code="at0017"><items id="text">Naziv</items><items id="description">*The prefix or title used by the subject. (en)</items><items id="comment">e.g. 'Mr', 'Mrs', 'Ms', 'Dr', 'Lord'</items></items><items code="at0018"><items id="text">Naslavljanje</items><items id="description">*Additional term used following a person name. (en)</items><items id="comment">e.g. 'Snr'</items></items><items code="at0019"><items id="text">*Professional name (en)</items><items id="description">*The name used by the subject for business or professional purposes. (en)</items></items><items code="at0020"><items id="text">*Registered name (en)</items><items id="description">*The name by which the subject is officially registered. (en)</items></items><items code="at0021"><items id="text">*Reporting name (en)</items><items id="description">*The subject’s name as it is to be used for reporting, when used with a specific identifier. (en)</items></items><items code="at0022"><items id="text">Izbrano ime</items><items id="description">*Indicates that this is the name by which a person chooses to be identified. (en)</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.specimen.v0"><term_definitions language="sl"><items code="at0000"><items id="text">Vzorec</items><items id="description">*To record details of a laboratory specimen. (en)</items></items><items code="at0001"><items id="text">Laboratorijska številka vzorca</items><items id="description">*Unique identifier of the specimen, normally assigned by the laboratory. (en)</items><items id="comment">Sometimes called the Accession Identifier.</items></items><items code="at0003"><items id="text">Številka starša vzorca</items><items id="description">*Unique identifier of the parent specimen, where the specimen is split into sub-samples. (en)</items></items><items code="at0005"><items id="text">Potencialno tveganje</items><items id="description">*Any risk or biohazard associated with collecting or handling the specimen. (en)</items></items><items code="at0007"><items id="text">Poseg</items><items id="description">*The method of collection to be used eg Venepuncture, biopsy, resection. (en)</items></items><items code="at0008"><items id="text">Pogoji odvzema</items><items id="description">*Any conditions to be met before the sample should be taken. (en)</items><items id="comment"> e.g. fasting, 'full bladder', 'sterile field' or any special instructions on the handling or immediate processing of the sample e.g. centrifuge on receipt. &#13;
&#13;
Can also be used to document any known deviations from collection or handling instructions e.g patient was not fasted.</items></items><items code="at0013"><items id="text">Mesto odvzema</items><items id="description">*The anatomical site(s) from where the specimen was taken. (en)</items></items><items code="at0015"><items id="text">Datum in ura odvzema</items><items id="description">*The date and time that collection has been ordered to take place or has taken place. (en)</items></items><items code="at0027"><items id="text">Fizične lastnosti</items><items id="description">*Dimensions / weight / quantity of sample or other physical details of a bodily fluid. Set as unbounded to allow variations e.g Weight of prostatic gland with and without seminal vesicles. (en)</items></items><items code="at0029"><items id="text">Vrsta vzorca</items><items id="description">*The type of specimen to be collected e.g venous blood, prostatic biopsy. (en)</items></items><items code="at0034"><items id="text">Datum in ura sprejema</items><items id="description">*The date and time that the sample was received at the laboratory. (en)</items></items><items code="at0039"><items id="text">Kakovost vzorca</items><items id="description">*Problems with the received specimen. (en)</items></items><items code="at0041"><items id="text">Uporabnost za testiranje</items><items id="description">*Is the specimen adequate for testing? (en)</items></items><items code="at0042"><items id="text">Težave prejetega vzorca</items><items id="description">*Specific issue with a received specimen. (en)</items></items><items code="at0044"><items id="text">Težave pri laboratorijski obdelavi</items><items id="description">*Issue arising with handling or processing of the specimen within the laboratory. (en)</items></items><items code="at0045"><items id="text">Komentar</items><items id="description">*An additional text comment on the quality of the received specimen. (en)</items></items><items code="at0046"><items id="text">Obdelava</items><items id="description">*Workflow of specimen processing/handling. (en)</items></items><items code="at0056"><items id="text">Napaka pri rokovanju vzorca</items><items id="description">*An error arose when handling the specimen. (en)</items></items><items code="at0057"><items id="text">Starost</items><items id="description">*The specimen was too old to analyse accurately. (en)</items></items><items code="at0058"><items id="text">Nesreča v laboratoriju</items><items id="description">*An accident occurred with the sample in the laboratory. (en)</items></items><items code="at0059"><items id="text">Tehnična napaka</items><items id="description">*The specimen could not be analysed for technical reasons. (en)</items></items><items code="at0062"><items id="text">Uporaben</items><items id="description">*The specimen is of sufficient quality to allow reporting. (en)</items></items><items code="at0063"><items id="text">Neuporaben - obdelan</items><items id="description">*The specimen is unsatisfactory but has been processed. (en)</items></items><items code="at0064"><items id="text">Neuporaben - neobdelan</items><items id="description">*The specimen is unsatisfactory and has not been processed. (en)</items></items><items code="at0067"><items id="text">Okoliščine odvzema</items><items id="description">*Identification of the setting at which the specimen was collected &#13;
from a subject of care. The specimen is often collected by a &#13;
healthcare provider, but may be collected directly by the patient or carer at home. (en)</items><items id="comment">This specifies the specimen collection location within the healthcare&#13;
environment. It enables the laboratory to ask questions about the&#13;
collection of the specimen, if required. The specimen collection&#13;
setting may provide additional information relevant to the analysis &#13;
of the result.</items></items><items code="at0068"><items id="text">Podrobnosti obdelave</items><items id="description">*The specimen preparation cluster allows detailed recording of a particular preparation step e.g staining or fixation. (en)</items></items><items code="at0070"><items id="text">ID - vzorec odvzel</items><items id="description">*Identifier of the person or agency responsible for collecting the specimen. (en)</items></items><items code="at0071"><items id="text">Vzorec odvzel</items><items id="description">*The person or organisation responsible for collecting the specimen. (en)</items></items><items code="at0079"><items id="text">Skupina posega</items><items id="description">*Additional detailed description of method of sample collection. (en)</items></items><items code="at0080"><items id="text">Število koščkov</items><items id="description">*The total number of containers holding this specimen. (en)</items></items><items code="at0081"><items id="text">Povezani vzorec</items><items id="description">*Details of a related specimen. (en)</items></items><items code="at0083"><items id="text">Dodatne podrobnosti odvzema</items><items id="description">*Addtional details related to specific collection methods e.g. needle biopsy. (en)</items></items><items code="at0085"><items id="text">Podrobnosti posode</items><items id="description">*Details of container(s) used. (en)</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.anatomical_location.v1"><term_definitions language="sl"><items code="at0000"><items id="text">Anatomska lokacija</items><items id="description">*A physical site on or within the human body.(en)</items></items><items code="at0001"><items id="text">Ostali odstranjeni organi</items><items id="description">*Identification of a single physical site either on, or within, the human body.(en)</items><items id="comment">*This data element is the only mandated data point in this archetype and should be used as the primary data point to record an anatomical location with a commonly used name. It is strongly recommended that 'Body site name' be recorded as specifically as is anatomically possible. For example: record 'upper eyelid' rather than recording 'eyelid' with 'upper' as a qualifier; 'fifth rib' rather than 'rib' with a numeric qualifier. Use the other data elements for laterality, aspect, region and anatomical line to provide more detail.&#13;
&#13;
This data element should be coded with a terminology capable of triggering decision support, where possible - an appropriate termset for use here could comprise individual concepts or a list of precoordinated terms. Free text should be used only if there is no appropriate terminology available.&#13;
&#13;
If body site name is already identified in the parent archetype, then this data element may be redundant. Alternatively, a use case has been identified where the value may be duplicated into this element to support semantic querying using this archetype, rather than the data element within the parent.(en)</items></items><items code="at0002"><items id="text">Lateralno</items><items id="description">*The side of the body on which the identified  body site is located.(en)</items><items id="comment">*If the identified body site has no laterality, this data element should not have a value. &#13;
If the 'Body site name' data element uses pre-coordinated terms that include laterality, then this data element is redundant.(en)</items></items><items code="at0003"><items id="text">*Left(en)</items><items id="description">*Left side of the body.(en)</items></items><items code="at0004"><items id="text">*Right(en)</items><items id="description">*Right side of the body.(en)</items></items><items code="at0023"><items id="text">Opis</items><items id="description">*Narrative description that can be used to further refine and support the 'Body site name'.(en)</items><items id="comment">*For example: adjacent to the vermilion border; a tattoo covers the bottom half of this area.(en)</items></items><items code="at0053"><items id="text">Alternativne strukture</items><items id="description">*Additional detail about the anatomical site using alternative approaches to describe the same body site.(en)</items><items id="comment">*For example, relative location or precise locations using coordinates. (en)</items></items><items code="at0054"><items id="text">Multimedia</items><items id="description">*Image or other media used to support identification of the body site.(en)</items></items><items code="at0055"><items id="text">Anatomska linija</items><items id="description">*Additional detail using theoretical lines drawn through anatomical structures used to provide a consistent reference point on the human body.(en)</items><items id="comment">*Common anatomical lines have been included as a value set, which can be extended over time, plus a free text option. The additional use of this data element allows for recording of the typical position of the heart's apex beat at 5th intercostal space, left side, and mid-clavicular line. If the 'Body site name' data element uses pre-coordinated terms that include anatomical line, then this data element is redundant.(en)</items></items><items code="at0056"><items id="text">*Midaxillary line(en)</items><items id="description">*Line running vertically down the surface of the body, passing through the apex of the axilla.(en)</items></items><items code="at0057"><items id="text">*Anterior axillary line(en)</items><items id="description">*Line running vertically down the surface of the body, passing through the anterior axillary skinfold.(en)</items></items><items code="at0058"><items id="text">*Posterior axillary line(en)</items><items id="description">*Line running vertically down the surface of the body, passing through the posterior axillary skinfold.(en)</items></items><items code="at0059"><items id="text">*Mid-clavicular line(en)</items><items id="description">*Line running vertically down the surface of the body, parallel to the midline and passing through the midpoint of the clavicle.(en)</items></items><items code="at0060"><items id="text">*Mid-pupillary line(en)</items><items id="description">*Line running vertically down the face through the midpoint of the pupil when looking directly forward.(en)</items></items><items code="at0062"><items id="text">*Midline(en)</items><items id="description">*Line running vertically which divides the body into left and right portions, passing through the head, spinal cord, and umbilicus. Alternatively it can refer to a line dividing a body part into two equal portions, for example a digit.(en)</items></items><items code="at0063"><items id="text">*Mid-scapular line(en)</items><items id="description">*Line running vertically down the posterior surface of the body, parallel to the midline and passing through the inferior point of the scapula.(en)</items></items><items code="at0064"><items id="text">Aspekt</items><items id="description">*Qualifying detail about the specific aspect of the identified body site.(en)</items><items id="comment">*Use to increase precision of identification of the body site, if required. Common aspects have been included as a value set, which can be extended over time, plus a free text option. Assumes that the body is being described while in the anatomical position. For example: proximal urethra; plantar aspect of the left thumb. Multiple aspects can also be described, if required, by allowing for 0..2 occurrences. For example: a lesion may be on the left anterior/lateral (ie anterolateral) chest wall. If the 'Body site name' data element uses pre-coordinated terms that include the aspect, then this data element is redundant.(en)</items></items><items code="at0065"><items id="text">Specifično mesto</items><items id="description">*Additional detail using a specific region or a point on, or within, the identified body site.(en)</items><items id="comment">*Use to increase precision of identification of the body site, if required. For example, the upper right quadrant or McBurney's point on the abdominal wall or interphalangeal joint of the great toe. If the 'Body site name' data element uses pre-coordinated terms that include the specific site, then this data element is redundant.(en)</items></items><items code="at0067"><items id="text">*Medial(en)</items><items id="description">*Towards the midline of the body site.(en)</items></items><items code="at0068"><items id="text">*Lateral(en)</items><items id="description">*Towards the side, or edge, of the body site.(en)</items></items><items code="at0069"><items id="text">*Superior(en)</items><items id="description">*Above the body site, often meaning towards the head.(en)</items></items><items code="at0070"><items id="text">*Inferior(en)</items><items id="description">*Below the body site, often meaning towards the feet.(en)</items></items><items code="at0071"><items id="text">*Anterior(en)</items><items id="description">*Towards the front, or ventral surface, of  the body site.(en)</items></items><items code="at0072"><items id="text">*Posterior(en)</items><items id="description">*Towards the back, or dorsal surface, of the body site.(en)</items></items><items code="at0073"><items id="text">*Proximal(en)</items><items id="description">*More central or closer to the point of attachment, and usually describing part of a limb, digit or appendage.(en)</items></items><items code="at0074"><items id="text">*Distal(en)</items><items id="description">*More peripheral, or further from the point of attachment, and usually describing part of a limb, digit or appendage.(en)</items></items><items code="at0075"><items id="text">*Palmar(en)</items><items id="description">*Towards the palm of the hand.(en)</items></items><items code="at0076"><items id="text">*Plantar(en)</items><items id="description">*Towards the sole of the foot.(en)</items></items><items code="at0077"><items id="text">*Mid(en)</items><items id="description">*In the middle of the body site.(en)</items></items><items code="at0078"><items id="text">*Oral(en)</items><items id="description">*Towards the mouth. Usually used to describe locations within the digestive system.(en)</items></items><items code="at0079"><items id="text">*Anal(en)</items><items id="description">*Towards the anus. Usually used to describe locations within the digestive system.(en)</items></items><items code="at0080"><items id="text">*Deep(en)</items><items id="description">*Away from the surface of the body site.(en)</items></items><items code="at0081"><items id="text">*Superficial(en)</items><items id="description">*Towards the surface of the body site.(en)</items></items><items code="at0082"><items id="text">*Dorsal(en)</items><items id="description">*Towards the back of the hand or top of the foot. To be used as opposites of palmar or plantar, not as a synonym of posterior.(en)</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.specimen_procedure_details_zora.v0"><term_definitions language="sl"><items code="at0000"><items id="text">Podrobnosti obdelave vzorcev</items><items id="description">*unknown (en)</items></items><items code="at0007"><items id="text">Anatomske posebnosti</items><items id="description">*</items></items><items code="at0008"><items id="text">Neodstranjeni organi</items><items id="description">*</items></items><items code="at0009"><items id="text">Mrzli rez</items><items id="description">*</items></items><items code="at0010"><items id="text">Morcelacija</items><items id="description">*</items></items><items code="at0011"><items id="text">Obravnava vzorca</items><items id="description">*</items></items></term_definitions></component_ontologies><component_ontologies archetype_id="openEHR-EHR-CLUSTER.specimen_container.v0"><term_definitions language="sl"><items code="at0006"><items id="text">Kaseta za tkivo</items><items id="description">**(en)</items></items><items code="at0007"><items id="text">Kaseta za mikro tkiva</items><items id="description">**(en)</items></items><items code="at0008"><items id="text">Viala</items><items id="description">**(en)</items></items><items code="at0009"><items id="text">Objektno stekelce</items><items id="description">**(en)</items></items><items code="at0010"><items id="text">Kontejner</items><items id="description">**(en)</items></items><items code="at0011"><items id="text">Mreža za elektronski mikroskop</items><items id="description">**(en)</items></items><items code="at0012"><items id="text">Vodnjak</items><items id="description">**(en)</items></items><items code="at0000"><items id="text">Posoda vzorca</items><items id="description">*Details of a specimen container. This is often integral to workflow and reporting of pathology specimens, particularly antamical and histological pathology specimens.(en)</items></items><items code="at0002"><items id="text">ID območja odvzema</items><items id="description">*Identifier of the place from where the container should be collected.(en)</items></items><items code="at0003"><items id="text">Oznaka posode</items><items id="description">*The unique identifier given to the container. May be multiple.(en)</items></items><items code="at0005"><items id="text">Vrsta posode</items><items id="description">*The type of container.(en)</items></items><items code="at0013"><items id="text">Opis</items><items id="description">*A text description of the container.(en)</items></items><items code="at0024"><items id="text">Datum in ura transportnega prevzema</items><items id="description">*The data and time that the specimen was uplifted for transportation to the laboratory.(en)</items></items><items code="at0025"><items id="text">ID transporterja</items><items id="description">*Identifier of person or agency responsible for transporting the container to the lab.(en)</items></items><items code="at0026"><items id="text">Transportni medij</items><items id="description">*Any special fixative or transport medium requirements.(en)</items></items><items code="at0028"><items id="text">*Cluster(en)</items><items id="description">**(en)</items></items></term_definitions></component_ontologies><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0071]"><items id="fhir_mapping">Specimen.collection.collector</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0013]"><items id="fhir_mapping">Specimen.collection.sourceSite</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0027]"><items id="fhir_mappings">Specimen.collection.quantity</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0070]"><items id="fhir_mapping">Specimen.collection.collector</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0046]/items[at0001]"><items id="fhir_mapping">Specimen.accessionIdentifier</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0046]/items[at0034]"><items id="fhir_mapping">Specimen.receivedTime</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0007]"><items id="fhir_mapping">Specimen.collection.method</items></annotations><annotations path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[at0029]"><items id="fhir_mapping">Specimen.type</items></annotations><constraints><attributes><rm_attribute_name>value</rm_attribute_name><children><default_value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="DV_CODED_TEXT"><defining_code><terminology_id><value>B04_request_service_name</value></terminology_id><code_string>1</code_string></defining_code></default_value></children><differential_path>[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[at0121]</differential_path></attributes><attributes><rm_attribute_name>value</rm_attribute_name><children><default_value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="DV_CODED_TEXT"><defining_code><terminology_id><value>BE_specimen_treatment</value></terminology_id><code_string>1</code_string></defining_code></default_value></children><differential_path>[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[openEHR-EHR-CLUSTER.specimen_procedure_details_zora.v0]/items[at0011]</differential_path></attributes><attributes><rm_attribute_name>value</rm_attribute_name><children><default_value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="DV_CODED_TEXT"><defining_code><terminology_id><value>AC_container_type</value></terminology_id><code_string>1</code_string></defining_code></default_value></children><differential_path>[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities[at0001]/description[at0009]/items[openEHR-EHR-CLUSTER.specimen.v0]/items[openEHR-EHR-CLUSTER.specimen_container.v0]/items[at0005]</differential_path></attributes></constraints><view><constraints path="[openEHR-EHR-COMPOSITION.request.v1]/content[openEHR-EHR-INSTRUCTION.service_request.v1]/activities"><items id="VisibleInView"><value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema" xsi:type="xs:string">activities</value></items></constraints></view></template>